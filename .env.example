# Path to the SQLite DB file. Default: ./memories.db relative to server.py.
# ZETA_DB_PATH=

# Hard caps on tool arguments (defaults shown).
# ZETA_SUMMARY_TARGET=250  # advertised in docstrings; aims AIs toward this
# ZETA_SUMMARY_MAX_LEN=400  # hard cap; adds truncate past this (CR #33), updates reject
# ZETA_LIST_HARD_LIMIT=200
# ZETA_SEARCH_HARD_LIMIT=100

# Layered retrieval (detail levels on list_*/search_* tools).
# ZETA_INDEX_TRUNC_CHARS=100   # summary length at detail='index'
# ZETA_EXCERPT_BODY_CHARS=280  # body excerpt length at detail='excerpt'
# ZETA_BULK_MAX_CHARS=45000    # bulk_load_context transport guard — char
#                              # ceiling on `formatted`, independent of the
#                              # token budget (Claude Code spills ~52 KB+)

# Embeddings (CR #16). Set ZETA_EMBED_BACKEND=openai to enable; the
# semantic_search_memories / hybrid_search_memories / bulk_load_context
# tools are no-ops while backend='none'.
# ZETA_EMBED_BACKEND=none           # one of: none, openai
# ZETA_EMBED_MODEL=text-embedding-3-large
# ZETA_EMBED_DIMS=1024              # Matryoshka-truncated; native is 3072
# OPENAI_API_KEY=sk-...             # required when backend=openai
